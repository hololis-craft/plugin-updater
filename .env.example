# Pterodactyl SFTP接続情報
SFTP_HOST=sftp.example.com
SFTP_PORT=2022
SFTP_USERNAME=your-username
SFTP_PASSWORD=your-password
# SFTP_PRIVATE_KEY_PATH=~/.ssh/id_rsa

# Modrinth API (オプション - レート制限を回避するため)
# MODRINTH_API_KEY=your-api-key

# GitHub API (オプション - レート制限を回避するため)
# GITHUB_TOKEN=your-personal-access-token

# Spigot API (現在は不要、将来的に必要になる可能性)
# SPIGET_API_KEY=your-api-key
